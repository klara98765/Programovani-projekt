<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Filmoteka.Views.MovieDetailView">
  <Grid RowDefinitions="Auto,*" Margin="28">
    <DockPanel>
      <StackPanel DockPanel.Dock="Left" Spacing="4">
        <TextBlock Text="{Binding Movie.Title}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Foreground="#5f6368">
          <Run Text="{Binding Movie.Director}" />
          <Run Text=", " />
          <Run Text="{Binding Movie.ReleaseYear}" />
          <Run Text=" · " />
          <Run Text="{Binding Movie.StatusName}" />
        </TextBlock>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
        <Button Content="Zpět" Command="{Binding DataContext.BackCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        <Button Content="Upravit film" Command="{Binding DataContext.EditMovieCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" Classes="accent" />
      </StackPanel>
    </DockPanel>

    <Grid Grid.Row="1" ColumnDefinitions="*,330" Margin="0,18,0,0">
      <Border BorderBrush="#d7dadd" BorderThickness="1" CornerRadius="8">
        <ScrollViewer>
          <ItemsControl ItemsSource="{Binding Reviews}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#edf0f2" BorderThickness="0,0,0,1" Padding="16">
                  <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="6">
                      <TextBlock FontWeight="SemiBold">
                        <Run Text="{Binding Author}" />
                        <Run Text=" · " />
                        <Run Text="{Binding Rating}" />
                        <Run Text="/10" />
                      </TextBlock>
                      <TextBlock Text="{Binding ReviewedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                 Foreground="#5f6368"
                                 FontSize="12" />
                      <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Top"
                                Margin="16,0,0,0"
                                Tag="{Binding}">
                      <Button Content="Upravit"
                              Command="{Binding DataContext.EditReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}" />
                      <Button Content="Smazat"
                              Command="{Binding DataContext.DeleteReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                              CommandParameter="{Binding}" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>

      <Border Grid.Column="1" BorderBrush="#d7dadd" BorderThickness="1" CornerRadius="8" Padding="18" Margin="20,0,0,0">
        <StackPanel Spacing="12">
          <TextBlock Text="Recenze" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ErrorMessage}" Foreground="#b3261e" TextWrapping="Wrap" />

          <StackPanel Spacing="5">
            <TextBlock Text="Autor" />
            <TextBox Text="{Binding ReviewForm.Author}" Watermark="Např. Klára" />
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="Hodnocení 1-10" />
            <NumericUpDown Value="{Binding ReviewForm.Rating}" Minimum="1" Maximum="10" Increment="1" />
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="Text recenze" />
            <TextBox Text="{Binding ReviewForm.Text}" AcceptsReturn="True" Height="130" TextWrapping="Wrap" />
          </StackPanel>

          <Button Content="Uložit recenzi"
                  Command="{Binding DataContext.SaveReviewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  Classes="accent"
                  HorizontalAlignment="Right" />
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</UserControl>
