<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Filmoteka.Views.MovieFormView">
  <Grid RowDefinitions="Auto,Auto,*" Margin="28">
    <DockPanel>
      <StackPanel DockPanel.Dock="Left">
        <TextBlock Text="{Binding PageTitle}" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Text="Hlavní entita Film" FontSize="15" Foreground="#5f6368" />
      </StackPanel>
    </DockPanel>

    <TextBlock Grid.Row="1"
               Text="{Binding ErrorMessage}"
               Foreground="#b3261e"
               TextWrapping="Wrap"
               Margin="0,18,0,0" />

    <Border Grid.Row="2"
            BorderBrush="#d7dadd"
            BorderThickness="1"
            CornerRadius="8"
            Padding="22"
            MaxWidth="520"
            Margin="0,18,0,0"
            HorizontalAlignment="Left"
            VerticalAlignment="Top">
      <StackPanel Spacing="14">
        <StackPanel Spacing="5">
          <TextBlock Text="Název filmu" />
          <TextBox Text="{Binding Movie.Title}" Watermark="Např. Blade Runner" />
        </StackPanel>

        <StackPanel Spacing="5">
          <TextBlock Text="Režisér" />
          <TextBox Text="{Binding Movie.Director}" Watermark="Např. Ridley Scott" />
        </StackPanel>

        <StackPanel Spacing="5">
          <TextBlock Text="Rok vydání" />
          <NumericUpDown Value="{Binding Movie.ReleaseYear}" Minimum="1888" Maximum="2100" Increment="1" />
        </StackPanel>

        <StackPanel Spacing="5">
          <TextBlock Text="Status" />
          <ComboBox ItemsSource="{Binding Statuses}"
                    SelectedItem="{Binding SelectedStatus}"
                    MinWidth="240">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
          <Button Content="Zrušit" Command="{Binding CancelCommand}" />
          <Button Content="Uložit" Command="{Binding SaveCommand}" Classes="accent" />
        </StackPanel>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
