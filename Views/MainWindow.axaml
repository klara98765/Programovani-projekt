<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Filmoteka.Views"
        xmlns:viewModels="clr-namespace:Filmoteka.ViewModels"
        x:Class="Filmoteka.Views.MainWindow"
        Title="Filmotéka"
        Width="1000"
        Height="680"
        MinWidth="820"
        MinHeight="560">
  <Window.DataTemplates>
    <DataTemplate DataType="{x:Type viewModels:MovieListViewModel}">
      <views:MovieListView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:MovieDetailViewModel}">
      <views:MovieDetailView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:MovieFormViewModel}">
      <views:MovieFormView />
    </DataTemplate>
  </Window.DataTemplates>

  <ContentControl Content="{Binding CurrentViewModel}" />
</Window>
